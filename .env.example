# Rapora — environment configuration.
# Copy this file to .env and fill in your values:   cp .env.example .env
# .env is gitignored — never commit real secrets.

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ENV_TYPE=dev
ALLOWED_HOSTS=localhost,127.0.0.1,backend
DOMAIN_NAME=http://localhost:8000
SWAGGER_ROOT_URL=http://localhost:8000

# ── PostgreSQL (external) ────────────────────────────────────────────────────
# Bring your own PostgreSQL 14+. The app MUST connect as a NON-superuser role so
# Row-Level Security is enforced — see RLS_SETUP.md to create the database and
# role. Use host.docker.internal to reach a database on the Docker host, or a
# hostname / IP for a remote server.
DBNAME=rapora
DBUSER=rapora
DBPASSWORD=change-me
DBHOST=host.docker.internal
DBPORT=5432

# ── Redis (external) ─────────────────────────────────────────────────────────
# Bring your own Redis. Choose logical DB indexes that don't collide with other
# apps sharing the instance.
CELERY_BROKER_URL=redis://host.docker.internal:6379/0
CELERY_RESULT_BACKEND=redis://host.docker.internal:6379/1

# ── Published host ports ─────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── Super admin ──────────────────────────────────────────────────────────────
# Accounts whose email is on this domain get platform-wide access.
SUPERADMIN_EMAIL_DOMAIN=rapora.app

# ── Email ────────────────────────────────────────────────────────────────────
# Dev default prints emails to stdout. For real delivery via SMTP, set:
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST=smtp.your-provider.com
#   EMAIL_PORT=465            # 465 + EMAIL_USE_SSL=True, or 587 + EMAIL_USE_TLS=True
#   EMAIL_HOST_USER=you@your-domain.com
#   EMAIL_HOST_PASSWORD=your-mailbox-password
#   EMAIL_USE_SSL=True
#   EMAIL_USE_TLS=False
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@localhost
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=admin

# ── CORS / CSRF ──────────────────────────────────────────────────────────────
CORS_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# ── Google OAuth (optional — leave blank to disable) ─────────────────────────
# Create an OAuth 2.0 Web client in Google Cloud Console. Register the redirect
# URI <FRONTEND_ORIGIN>/login. GOOGLE_LOGIN_DOMAIN is the frontend origin used
# to build that redirect URI; CLIENT_ID/SECRET are used by the backend to
# exchange the auth code.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_LOGIN_DOMAIN=http://localhost:5173

# ── Frontend ─────────────────────────────────────────────────────────────────
# Base URL of the Django API as reached by the BROWSER (client-side).
PUBLIC_DJANGO_API_URL=http://localhost:8000
# Optional: API URL used for SERVER-SIDE rendering only. Set to the internal
# container address (e.g. http://backend:8000) so SSR talks to the backend
# directly instead of round-tripping a public proxy/tunnel. Falls back to
# PUBLIC_DJANGO_API_URL if unset.
INTERNAL_API_URL=http://backend:8000
# Public origin of the frontend itself. The SvelteKit (adapter-node) production
# server uses this for its CSRF origin check on POST form actions. Set it to the
# exact public URL you serve the app from.
FRONTEND_ORIGIN=http://localhost:5173
# Base URL Django uses to build links in emails (magic-link sign-in, etc.).
# Set to the public URL where users open the app.
FRONTEND_URL=http://localhost:5173
# Comma-separated extra hostnames the Vite dev server may serve (only used when
# running `pnpm dev`). Empty = localhost only.
VITE_ALLOWED_HOSTS=
